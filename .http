### ============================================================
### CREATE - Valid
### ============================================================

### Create User 1
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "johndoe",
  "email": "john@example.com",
  "password": "Password1!",
  "firstName": "John",
  "lastName": "Doe",
  "bio": "Hello I am John"
}

### Create User 2 (for follow/unfollow testing)
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "janedoe",
  "email": "jane@example.com",
  "password": "Password1!",
  "firstName": "Jane",
  "lastName": "Doe"
}

### Create User 3 (minimal — no lastName, no bio)
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "minimaluser",
  "email": "minimal@example.com",
  "password": "Password1!",
  "firstName": "Minimal"
}

### ============================================================
### CREATE - Validation failures
### ============================================================

### Missing username
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "email": "nousername@example.com",
  "password": "Password1!",
  "firstName": "No"
}

### Missing email
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "noemail",
  "password": "Password1!",
  "profile": { "firstName": "No" }
}

### Missing password
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "nopassword",
  "email": "nopassword@example.com",
  "profile": { "firstName": "No" }
}

### Missing profile
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "noprofile",
  "email": "noprofile@example.com",
  "password": "Password1!"
}

### Missing profile.firstName
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "nofirstname",
  "email": "nofirstname@example.com",
  "password": "Password1!",
  "lastName": "Doe"
}

### Password too short (under 6 chars)
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "shortpass",
  "email": "shortpass@example.com",
  "password": "Ab1!",
  "profile": { "firstName": "Short" }
}

### Password missing uppercase
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "nouppercase",
  "email": "nouppercase@example.com",
  "password": "password1!",
  "profile": { "firstName": "No" }
}

### Password missing lowercase
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "nolowercase",
  "email": "nolowercase@example.com",
  "password": "PASSWORD1!",
  "profile": { "firstName": "No" }
}

### Password missing special character
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "nospecial",
  "email": "nospecial@example.com",
  "password": "Password1",
  "profile": { "firstName": "No" }
}

### Duplicate email
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "johndoe2",
  "email": "john@example.com",
  "password": "Password1!",
  "firstName": "John"
}

### Duplicate username
POST http://localhost:3000/api/users
Content-Type: application/json

{
  "username": "johndoe",
  "email": "different@example.com",
  "password": "Password1!",
  "firstName": "yep"
